<!-- Load React. -->
<!-- Note: when deploying, replace "development.js" with "production.min.js". -->
<script src="https://unpkg.com/react@16/umd/react.development.js" crossorigin></script>
<script src="https://unpkg.com/react-dom@16/umd/react-dom.development.js" crossorigin></script>

    


<div class="Container Container--wide account-wrapper">
  <header class="PageHeader">
    <a
      href="{{ routes.account_logout_url }}"
      class="PageHeader__Back Heading Text--subdued Link Link--primary u-h7 logout-myaccount"
      >{{ "customer.account.logout" | t }}</a
    >
    <div id="mr-customer-id" data-customer-id = "{% if customer %}{{customer.id}}{% endif %}"></div>
    <div class="SectionHeader account-header">
      <h1 class="SectionHeader__Heading Heading u-h1">
        {{ "customer.account.title" | t }}
      </h1>
      <p class="SectionHeader__Description account-welcome">
        {{ "customer.account.welcome" | t: first_name:customer.first_name }}
      </p>
    </div>
  </header>

  <div class="PageLayout PageLayout--breakLap">
    {%- comment -%}
    --------------------------------------------------------------------------------------------------------------------
    ORDER HISTORY
    --------------------------------------------------------------------------------------------------------------------
    {%- endcomment -%}

    <div class="PageLayout__Section PageLayout__Section--primary">

      <div class="mr-model-background" style="display:none">
        <div class="mr-model-loading loading"></div>
      </div>
      <div class="mr-model-wrapper" style="display:none">
          <div class="model-close" onclick="mrModelClose()">
            <svg width="22" height="23" viewBox="0 0 22 23" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="0.353553" y1="0.646447" x2="21.3536" y2="21.6464" stroke="black"/>
              <line x1="21.3536" y1="1.35355" x2="0.353554" y2="22.3536" stroke="black"/>
            </svg>
          </div>
          <div class="model-title">SUCCESS!</div>
          <div class="model-text">Your voucher has been applied to your cart.</div>
          <a href="collections/all" class="model-continue">CONTINUE SHOPPING</a>
      </div>
      

      <section class="account-page-tabs">
        <input type="radio" name="account-tabs" id="account-details" checked />
        <label class="account-page-nav" for="account-details">My Details</label>
        <input type="radio" name="account-tabs" id="account-orders-online" />
        <label class="account-page-nav" for="account-orders-online">My Orders</label>
        <!-- <input type="radio" name="account-tabs" id="account-orders-offline" />
        <label class="account-page-nav" for="account-orders-offline">My Offline Orders</label> -->

        {%- if settings.enable_mates -%}
        <input type="radio" name="account-tabs" id="account-mates" />
        <label class="account-page-nav account-page-last-nav" for="account-mates">Mates Benefits</label>
        {%- endif -%}
        
        <div class="account-tabs-divider"></div>
        <div class="account-page-tabs-content">
          <section class="account-tab account-details-tab">
            <div class="account-details-container">
              {%- if request.locale.iso_code == 'ja' -%}
              <div class="account-field-row">
                <div class="account-form-item column">
                  <input
                    type="text"
                    class="account-form-input"
                    name="customer[last_name] account-name"
                    aria-label="{{ 'customer.last_name' | t }}"
                    value="{{customer.last_name}}"
                    disabled
                  />
                  <label class="account-form-label">{{ "customer.register.last_name" | t }}</label>
                </div>

                <div class="account-form-item column">
                  <input
                    type="text"
                    class="account-form-input account-name"
                    name="customer[first_name]"
                    aria-label="{{ 'customer.register.first_name' | t }}"
                    value="{{customer.first_name}}"
                    disabled
                  />
                  <label class="account-form-label">{{ "customer.register.first_name" | t }}</label>
                </div>
              </div>
              {%- else -%}
              <div class="account-field-row">
                <div class="account-form-item column">
                  <input
                    type="text"
                    class="account-form-input account-name"
                    name="customer[first_name]"
                    aria-label="{{ 'customer.register.first_name' | t }}"
                    value="{{customer.first_name}}"
                    disabled
                  />
                  <label class="account-form-label">{{ "customer.register.first_name" | t }}</label>
                </div>

                <div class="account-form-item column">
                  <input
                    type="text"
                    class="account-form-input account-name"
                    name="customer[last_name]"
                    aria-label="{{ 'customer.register.last_name' | t }}"
                    value="{{customer.last_name}}"
                    disabled
                  />
                  <label class="account-form-label">{{ "customer.register.last_name" | t }}</label>
                </div>
              </div>
              {%- endif -%}
              <div class="account-field-row">
                <div class="account-form-item account-form-birthday column">
                  <input
                    type="date"
                    class="account-form-input account-birthday"
                    name="customer[note][birthday]"
                    aria-label="{{ 'customer.register.birthday' | t }}"
                    value={{customer.notes.birthday}}
                  />
                  <label class="account-form-label">DATE OF BIRTH</label>
                </div>

                <div class="account-form-item column">
                  <input
                    type="text"
                    class="account-form-input"
                    id="account-form-phone"
                    name="customer[phone]"
                    aria-label="{{ 'customer.register.phone' | t }}"
                    value="{%if customer.phone%}{{customer.phone}}{%else%}{{customer.default_address.phone}}{% endif %}"
                  />
                  <label class="account-form-label">MOBILE</label>
                </div>
              </div>
              <div class="account-field-row">
                <div class="account-form-item column account-email">
                  <input
                    type="email"
                    class="account-form-input"
                    id = "account-form-email"
                    name="customer[email]"
                    aria-label="{{ 'customer.register.email' | t }}"
                    value="{{customer.email}}"
                    readonly
                  />
                  <label class="account-form-label">{{ "customer.register.email" | t }}</label>
                </div>
              </div>
              <div class="account-toggle-header account-header-communications">Communications Preferences</div>
              <div class="account-toggles-row">
                <div class="account-toggles-item row">
                  <input
                    type="checkbox"
                    id="account-communications-email"
                    class="account-form-checkbox"
                  />
                  <label for="account-communications-email">Email</label>
                </div>
                <div class="account-toggles-item row">
                  <input
                    type="checkbox"
                    id="account-communications-sms"
                    class="account-form-checkbox"
                  />
                  <label for="account-communications-sms">SMS</label>
                </div>
                <!-- <div class="account-toggles-item row">
                  <input
                    type="checkbox"
                    id="account-communications-unsub"
                    class="account-form-checkbox"
                  />
                  <label for="account-communications-unsub">Unsubscribe From All</label>
                </div> -->
              </div>
              <div class="account-toggle-header brand-preferences-header">Brand Preferences</div>
              <div class="account-toggles-row brand-preferences-rows">
                <div class="account-toggles-item row">
                  <input type="checkbox" id="account-brand-sw" class="account-form-checkbox" />
                  <label for="account-brand-sw">Saltwater Wine</label>
                </div>
                <div class="account-toggles-item row">
                  <input type="checkbox" id="account-brand-sr" class="account-form-checkbox" />
                  <label for="account-brand-sr">Stormriders</label>
                </div>
                <div class="account-toggles-item row">
                  <input type="checkbox" id="account-brand-rh" class="account-form-checkbox" />
                  <label for="account-brand-rh">Red Herring Surf</label>
                </div>
                <div class="account-toggles-item row">
                  <input type="checkbox" id="account-brand-bc" class="account-form-checkbox" disabled checked/>
                  <label for="account-brand-bc">BoardCollective</label>
                </div>
              </div>
            </div>
            <div class="account-details-save">
              <button id="account-details-save-btn" class="My-account-btn Button Button--primary Button--half" data-customer-id="{{customer.id}}">
                Save
              </button>
            </div>
            <div class="account-divider"></div>
            <section class="account-page-reset">
              <span>Forgot your password?</span>
              <a href="/account/login?return_url=%2Faccount">
                <button id="reset-password" class="My-account-btn Form__Submit Button Button--primary Button--full">
                  Reset My Password
                </button>
              </a>
            </section>
            <div class="account-divider"></div>
          </section>
