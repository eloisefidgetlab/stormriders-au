          <!-- offline order -->
          <section class="account-tab account-orders-offline-tab">
            <div class="btn-switch-button">
              <input type="radio" id="online-order-history-switch" name="order-switch" value="ONLINE ORDER" checked>
              <label class="order-history-switch" id="online-order-switch-label" for="online-order-history-switch">ONLINE ORDER</label>
              <input type="radio" id="offline-order-history-switch" name="order-switch" value="OFFLINE ORDER">
              <label class="order-history-switch" id="offline-order-switch-label" for="offline-order-history-switch">INSTORE ORDER</label>
            </div>
            <div class="on-line-wrapper">
              {%- if customer.orders.size == 0 -%}
              <div class="Segment">
                <div class="Segment__Content">
                  <p>{{ "customer.account.no_orders_content" | t }}</p>
                </div>
              </div>
              {%- else -%} {%- paginate customer.orders by 25 -%}
              <div class="TableWrapper" id="order-table-desktop-online">
                <table class="AccountTable Table Table--large">
                  <thead class="Text--subdued">
                    <tr>
                      <th>{{ "customer.orders.order_number" | t }}</th>
                      <th>{{ "customer.orders.date" | t }}</th>
                      <th>Store</th>
                      <!-- <th>{{ "customer.orders.payment_status" | t }}</th>
                      <th>{{ "customer.orders.fulfillment_status" | t }}</th> -->
