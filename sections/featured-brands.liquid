<section id="section-{{ section.id }}" class="shopify-section--featured-brands shopify-section--featured-brands-index">
  <div class="featured-brands-wrapper">
    <h2>{{ section.settings.title }}</h2>
    <div class="brand-logo-wrapper">
      {%- for block in section.blocks -%}
        <div class="brand-logo-item">
          <a href="{{ block.settings.link }}">
            <img src="{{ block.settings.image | img_url: 'medium' }}" alt="brand-image">
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  
</style>

{% schema %}
{
  "name": "Featured Brands",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand link"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Collection",
      "name": "Featured Brands",
      "settings": {}
    }
  ]
}
{% endschema %}