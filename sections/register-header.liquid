<section class="Section">
  <header class="signup-header PageHeader">
    {% if section.settings.banner_logos %}
      <img src="{{ section.settings.banner_logos | img_url: '1000x' }}">
    {% endif %}
    {% if section.settings.banner_heading %}
      <!-- <h1 class="banner-heading">{{section.settings.banner_heading}}</h1> -->
      <h1 class="banner-heading"><p>JOIN MATES OF BOARDCOLLECTIVE</p></h1>
    {% endif %}
  </header>
  <div class="signup-copy">
    <div class="signup-copy-title">{{ section.settings.heading }}</div>
    <div class="welcome-text-container">
      {{section.settings.welcome_text}}
    </div>
  </div>
  <div class="perks-container">
    {% for block in section.blocks %}
      {% case block.type %}    
        {% when 'perk' %}
          <div class="perk-block" {{ block.shopify_attributes }}>
            {% if block.settings.icon %}
              <img src="{{ block.settings.icon | img_url: '450x' }}">
            {% endif %}
              <div class="perk-block-title">{{ block.settings.text }}</div>
          </div>
          
      {% endcase %}
    {% endfor %}    
  </div>
</section>

{% schema %}
{
"name": "Sign Up Form",
"settings": [
  {
      "type": "image_picker",
      "id": "banner_logos",
      "label": "Banner Logos"
  },
  {
      "type": "richtext",
      "id": "banner_heading",
      "label": "Banner Heading",
      "default": "<p>Join Mates of BoardCollective</p>"
  },
  {
      "type": "text",
      "id": "heading",
      "label": "Header",
      "default": "Join the mates!"
  },
  {
      "type": "richtext",
      "id": "welcome_text",
      "label": "Welcome Text",
      "default": "<p>Hey Mate!</p>"
  }
],
"blocks": [
  {
    "name": "Perk Icons",
    "type": "perk",
    "settings": [
      {
        "type": "image_picker",
        "id": "icon",
        "label": "Icon"
      },
      {
        "type": "text",
        "id": "text",
        "label": "Icon Text"
      }
    ]
  }
]
}
{% endschema %}