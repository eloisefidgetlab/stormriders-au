<div class="featured-brands-wrapper all-brands-page">
  <h2>
    {{ section.settings.title }}
    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}
  </h2>
  <div class="brand-logo-wrapper">
    {%- for block in section.blocks -%}
      <div class="brand-logo-item">
        <a href="{% if block.settings.size_guide_link != blank %}{{ block.settings.size_guide_link }}{% endif %}">
          <img src="{{ block.settings.image | img_url: 'medium' }}" alt="brand-image">
        </a>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Size Guides Page",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Information"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Trading site link"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "size_guide_link",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}