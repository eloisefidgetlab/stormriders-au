<section class="Section Section--spacingNormal section-blogs-redherring" id="section-{{ section.id }}" data-section-type="article-list" data-section-id="{{ section.id }}">
  <div class="Container">
    {%- if section.settings.subheading != blank or section.settings.title != blank -%}
      <header class="SectionHeader SectionHeader--center">
        {%- if section.settings.subheading != blank -%}
          <h3 class="SectionHeader__SubHeading Heading u-h6">{{ section.settings.subheading | escape }}</h3>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="SectionHeader__Heading Heading u-h1">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- assign show_placeholders = false -%}

    <div class="ArticleListWrapper">
      <div class="ArticleList Grid Grid--m Grid--center">

        {% for block in section.blocks %}
          <div class="Grid__Cell 1/2--tablet 1/3--lap-and-up {% if forloop.index == 3 %}hidden-tablet{% endif %}">

            <a href="{{ block.settings.link }}" class="grid-link-wrapper">
              {% if block.settings.image %}
                  <img src="{{ block.settings.image | img_url: 'large'}}" alt="blog-image">
              {% endif %}
              
              <div class="blog__content">
                {% if block.settings.name %}
                    <h3 class="blog-name">{{ block.settings.name }}</h3class="blog-name">
                {% endif %}
    
                {% if block.settings.text %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}
    
              </div>
              <a href="{{ block.settings.link }}" class="read_more">Read More</a>
            </a>
          </div>
        {% endfor %}

      </div>
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="SectionFooter">
        <a href="{{ section.settings.button_link }}" class="Button Button--primary">{{ section.settings.button_text | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog posts",
  "class": "shopify-section--bordered",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Blog posts"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View all articles"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Blog",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Blog image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Blog name"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Blog text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Blog link"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Blog",
      "name": "Blogs Red Herring",
      "settings": {}
    }
  ]
}
{% endschema %}